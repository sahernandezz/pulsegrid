# --- Java / Maven ---
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
hs_err_pid*
.mvn/timing.properties

# --- GraalVM native build leftovers ---
*.build_artifacts.txt
backends/**/native/

# --- Node / Vite (frontend) ---
node_modules/
frontend/dist/
frontend/.vite/
*.local

# --- Python (runner / benchmark) ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# --- Benchmark outputs (raw evidence IS committed; transient is not) ---
benchmark/plots/output/*.png
# article-kit/ is generated by analyze.py — ignore its contents, keep the README
benchmark/article-kit/*
!benchmark/article-kit/README.md
runner/.runner-tmp/

# --- Secrets / env ---
.env
*.local.env

# --- OS / IDE / agent ---
.DS_Store
.idea/
*.iml
.vscode/
.claude/
