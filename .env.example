# =============================================================================
# PulseGrid — environment variables (copy to .env)
# =============================================================================
# docker-compose and the runner read these. Almost everything has a sensible
# default; the only thing changed between runs is INGEST_MODE.

# --- Ingestion mode (a measurement dimension) -------------------------------
# http  -> synchronous HTTP ingestion (POST /api/events).
# queue -> asynchronous ingestion via Kafka (requires the 'queue' profile).
INGEST_MODE=http

# --- Database (consumed by ALL backends) ------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pulsegrid
DB_USER=pulse
DB_PASSWORD=pulse

# --- Kafka (only when INGEST_MODE=queue) ------------------------------------
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=metric-events

# --- Server -----------------------------------------------------------------
SERVER_PORT=8080

# --- JVM options (JVM variants only; container-aware heap + Generational ZGC).
# ZGC (default since Java 25's UseZGC = generational) gives sub-millisecond GC
# pauses → much lower latency tails than G1 under high allocation. Measured: it
# cut p99.9 by 3-10x and lifted reactive throughput ~28% vs G1. Override to
# "-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC" to compare. Native variants ignore this.
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseZGC
