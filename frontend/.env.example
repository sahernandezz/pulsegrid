# Firebase web config for the frontend showcase.
# Copy to `.env` (git-ignored) and fill with your project's values from
# Firebase console → Project settings → Your apps → SDK setup and configuration.
# These end up in the client bundle (not secret), but are kept out of source control.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
